root = true

[*]                                                 # Aplicar a todos los archivos
charset = utf-8                                     # Codificación UTF-8
indent_style = space                                # Sangría con espacios (no tabs)
indent_size = 4                                     # 4 espacios por nivel de sangría
end_of_line = lf                                    # Fin de línea LF (Linux/Mac/Web)
trim_trailing_whitespace = true                   # Quitar espacios al final de línea
insert_final_newline = true                         # Asegurar una línea en blanco al final

[*.gd]                                              # Solo para archivos GDScript
# indent_style = tab                                # Descomentar si prefieres tabs
# indent_size = 4                                 # Opcional: definir tamaño específico

[*.tres]
# indent_style = space
# indent_size = 4

# Para archivos JSON (configuraciones, imports)
[*.json]
indent_size = 2                                     # JSON usa convencionalmente 2 espacios
